<UserControl 
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:LibraryApp.ViewModels"
    xmlns:models="using:LibraryApp.Models"
    x:Class="LibraryApp.Views.ActiveLoansView"
    x:DataType="vm:ActiveLoansViewModel">

    <StackPanel Margin="10">

        <TextBlock Text="Active Loans" FontSize="16" Margin="0,0,0,10"/>

        <ListBox ItemsSource="{Binding ActiveBorrowedBooks}">

            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:Book">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="{Binding Title}"/>
                        <TextBlock Text= " - "/>
                        <TextBlock Text="{Binding LoanedBy}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>

    </StackPanel>

</UserControl>