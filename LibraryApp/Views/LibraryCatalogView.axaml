<UserControl
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:vm="using:LibraryApp.ViewModels"
xmlns:models="using:LibraryApp.Models"
x:Class="LibraryApp.Views.LibraryCatalogView"
x:DataType="vm:LibraryCatalogViewModel">

    <StackPanel>

        <TextBlock Text="Library Catalog" FontSize="16"/>
        <TextBox Text="{Binding SearchText}" Width="200"/>

        <ListBox ItemsSource="{Binding Books}"
                 SelectedItem="{Binding SelectedBook}">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:Book">
                    <Border Padding= "8"  Margin= "0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}"
                                       FontSize= "16"
                                       FontWeight= "Bold"/>
                            <TextBlock Text= "{Binding Author}"/>
                            <TextBlock Text= "{Binding Isbn}"/>
                            <TextBlock Text= "{Binding AvailabilityText}"/>
                            <Button 
                                Command="{Binding $parent[UserControl].((vm:LibraryCatalogViewModel)DataContext).BorrowCommand}" 
                                CommandParameter="{Binding}"
                                CornerRadius="8" Background="#F97068" Foreground="White" MinWidth="100" Margin="0,5,0,0">
                                Borrow
                            </Button>

      
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </StackPanel>

</UserControl>