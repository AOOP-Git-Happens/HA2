<UserControl x:Class="LibraryApp.Views.LoginView"
             Background="#0C0A3E"
             x:DataType="vm:LoginViewModel"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns="https://github.com/avaloniaui"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LibraryApp.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">

    <UserControl.Styles>
        <Style Selector="Ellipse.spin, Border.spin">
            <Setter Property="RenderTransformOrigin" Value="50%,50%" />
            
            <Style.Animations>
                <Animation Duration="0:0:20" IterationCount="INFINITE">
                    <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="0.0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="360.0" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <Grid>
        <Ellipse Classes="spin"
                 Width="1100" Height="1100" 
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-500,-500,0,0"
                 Stroke="#F97068" StrokeThickness="50" 
                 StrokeDashArray="2,1,4,1,7,5,1,6,7">
            <Ellipse.RenderTransform>
                <RotateTransform Angle="0.0" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <Ellipse Classes="spin"
                 Width="400" Height="400" 
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-120,-75"
                 Stroke="#F97068" StrokeThickness="30" 
                 StrokeDashArray="2,1,4,1,7,5,1,6,7">
            <Ellipse.RenderTransform>
                <RotateTransform Angle="0.0" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <Border Classes="spin"
                CornerRadius="8"
                Background="White"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="50,50">
            <Border.RenderTransform>
                <RotateTransform Angle="0.0" />
            </Border.RenderTransform>

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"  
                        Spacing="20">

                <TextBox BorderBrush="#E0E0E0" CornerRadius="8" Foreground="#333333" Watermark="Username"/>
                <TextBox BorderBrush="#E0E0E0" CornerRadius="8" Foreground="#333333" PasswordChar="*" Watermark="Password"/>
                <Button CornerRadius="8" Background="#F97068" Foreground="White" MinWidth="200" >Login</Button>
                
            </StackPanel>
        </Border>
    </Grid>
</UserControl>