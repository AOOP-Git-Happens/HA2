 <UserControl x:Class="LibraryApp.Views.LoginView"
             Background="#0C0A3E"
             x:DataType="vm:LoginViewModel"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns="https://github.com/avaloniaui"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LibraryApp.ViewModels"
             d:DesignHeight="450"
             d:DesignWidth="800"
             mc:Ignorable="d">


    <Border CornerRadius="8"
        Background="White"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Padding="50,50">


        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"  
                    Spacing="20"
                    >

            <TextBox BorderBrush="#E0E0E0" CornerRadius="8" Foreground="#888888" Watermark="Username"/>
            <TextBox BorderBrush="#E0E0E0" CornerRadius="8" Foreground="#888888" PasswordChar="*" Watermark="Password"/>
            <Button CornerRadius="8" Background="#F97068" Foreground="White" MinWidth="200" >Login</Button>
            <Ellipse Fill="Blue" Width="58" Height="58" Canvas.Left="88" Canvas.Top="100"/>
            <

        </StackPanel>
    </Border>
</UserControl> 