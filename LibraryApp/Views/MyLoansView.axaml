<UserControl 
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:LibraryApp.ViewModels"
    xmlns:models="using:LibraryApp.Models"
    x:Class="LibraryApp.Views.MyLoansView"
    x:DataType="vm:MyLoansViewModel">

    <StackPanel Margin="10">

        <TextBlock Text="My Loans" FontSize="16"/>

        <ListBox ItemsSource="{Binding Loans}"
                 SelectedItem="{Binding SelectedLoan}">

            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:Loan">
                    <TextBlock Text="{Binding BookId}" />
                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>

    </StackPanel>

</UserControl>